# ─── Client Strategies ──────────────────────────────────────────────────
# Each client supports 3 strategies: fake (default) | local | real
# 'fake'  — canned responses, no API calls, no costs
# 'local' — local/self-hosted services (Anthropic fully supports this)
# 'real'  — production APIs, requires keys below

# AI — Chat uses AI SDK with two modes:
# 1. AI Gateway (production): set AI_GATEWAY_API_KEY
# 2. Claude Code CLI (local dev): leave AI_GATEWAY_API_KEY unset
#    Requires `claude` CLI installed and authenticated
# AI_GATEWAY_API_KEY=             # set to use AI Gateway, unset for local Claude Code
# EMPORA_MCP_URL=http://localhost:3000/api/mcp  # MCP server for Claude Code mode

# Address validation — Smarty
SMARTY_STRATEGY=fake
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=

